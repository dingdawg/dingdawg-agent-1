FROM node:20-slim AS base

LABEL maintainer="Innovative Systems Global LLC"
LABEL description="ISG Agent 1 — Bridges Service"

WORKDIR /app

# Create non-root user
RUN groupadd --gid 1001 isgagent && \
    useradd --uid 1001 --gid isgagent --shell /bin/false --create-home isgagent

# Copy package files and install dependencies
COPY bridges/package.json bridges/package-lock.json* ./
RUN npm ci --omit=dev 2>/dev/null || npm install --omit=dev

# Copy application code
COPY bridges/ ./

# Build TypeScript
RUN npm run build 2>/dev/null || echo "Build step skipped (no build script or TS not compiled)"

# Switch to non-root user
USER isgagent

CMD ["node", "dist/index.js"]
