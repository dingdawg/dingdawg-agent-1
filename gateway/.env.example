# =============================================================================
# DingDawg Agent 1 — Environment Variables Reference
# Copy this file to .env and fill in real values. Never commit .env to git.
# All ISG_AGENT_ vars are read by Pydantic-Settings (env_prefix = "ISG_AGENT_")
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Server will degrade or refuse to start without these
# -----------------------------------------------------------------------------

# HMAC secret key used for JWT signing. Generate with: openssl rand -hex 32
ISG_AGENT_SECRET_KEY=

# Admin user email address for bootstrapping the first admin account
ISG_AGENT_ADMIN_EMAIL=admin@example.com

# Absolute path to the SQLite database file inside the container
ISG_AGENT_DB_PATH=/data/agent.db

# Stripe live/test secret key (sk_live_... or sk_test_...)
ISG_AGENT_STRIPE_SECRET_KEY=

# SendGrid API key for transactional email delivery
ISG_AGENT_SENDGRID_API_KEY=

# -----------------------------------------------------------------------------
# DEPLOYMENT ENVIRONMENT
# -----------------------------------------------------------------------------

# Accepted: development | staging | production
# Controls error detail exposure and strict security gates.
ISG_AGENT_DEPLOYMENT_ENV=production

# Comma-separated list of allowed CORS origins
# Domain architecture:
#   dingdawg.com  — main website, landing page, marketing site (Vercel/Netlify, ISG corporate site)
#   dingdawg.app  — customer-facing PWA (Vercel, Agent 1 frontend)
#   dingdawg.ai   — agent-to-agent platform, API gateway (Railway, Agent 1 backend)
#   dingdawg.io   — developer docs, SDK reference, API documentation (static site, future)
ISG_AGENT_ALLOWED_ORIGINS=https://dingdawg.com,https://www.dingdawg.com,https://app.dingdawg.com,https://dingdawg.ai,https://dingdawg.io,https://www.dingdawg.ai

# Public frontend URL used in password-reset / verification email links
ISG_AGENT_FRONTEND_URL=https://app.dingdawg.com

# CRITICAL: Canonical public-facing backend URL.
# Set this to your custom domain to prevent the internal Railway hostname
# (e.g. wholesome-commitment-production-46df.up.railway.app) from leaking
# into agent cards, MCP discovery documents, widget configs, and OAuth redirects.
# Must be set in production. Leave blank only for local development.
ISG_AGENT_PUBLIC_URL=https://api.dingdawg.com

# -----------------------------------------------------------------------------
# SERVER BINDING
# -----------------------------------------------------------------------------

# Host interface — set to 0.0.0.0 in production containers
ISG_AGENT_HOST=0.0.0.0

# TCP port — Railway injects $PORT at runtime (Procfile passes it via uvicorn)
ISG_AGENT_PORT=8420

# Allow connections from non-localhost clients (must be true in production)
ISG_AGENT_ENABLE_REMOTE=true

# Number of uvicorn workers — keep at 1 for SQLite (write-lock avoidance)
ISG_AGENT_WORKERS=1

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
ISG_AGENT_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# LLM API KEYS
# -----------------------------------------------------------------------------

# Anthropic API key for Claude models
ISG_AGENT_ANTHROPIC_API_KEY=

# OpenAI API key for GPT models
ISG_AGENT_OPENAI_API_KEY=

# Google AI (Gemini) API key
ISG_AGENT_GOOGLE_API_KEY=

# Inception Labs API key for Mercury 2 diffusion model
ISG_AGENT_INCEPTION_API_KEY=

# -----------------------------------------------------------------------------
# STRIPE (additional)
# -----------------------------------------------------------------------------

# Stripe webhook endpoint secret (whsec_...) for signature verification
ISG_AGENT_STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for subscription tiers
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Stripe merchant identifier (defaults to dingdawg_platform)
ISG_AGENT_STRIPE_MERCHANT_ID=dingdawg_platform

# -----------------------------------------------------------------------------
# RESEND (primary email provider — 3K emails/month free, 5 RPS)
# https://resend.com/api-keys
# -----------------------------------------------------------------------------

# Resend API key (re_...)
ISG_AGENT_RESEND_API_KEY=

# Default sender address — must be from a verified Resend domain
ISG_AGENT_RESEND_FROM_EMAIL=noreply@dingdawg.com

# Optional display name shown in recipient's inbox (e.g. "DingDawg")
ISG_AGENT_RESEND_FROM_NAME=DingDawg

# -----------------------------------------------------------------------------
# SENDGRID (additional — fallback email provider)
# -----------------------------------------------------------------------------

# Sender email address for outbound mail
ISG_AGENT_SENDGRID_FROM_EMAIL=noreply@dingdawg.com

# Basic-auth credentials for SendGrid Inbound Parse webhook
ISG_AGENT_SENDGRID_INBOUND_USER=
ISG_AGENT_SENDGRID_INBOUND_PASS=

# -----------------------------------------------------------------------------
# TWILIO SMS
# -----------------------------------------------------------------------------

ISG_AGENT_TWILIO_ACCOUNT_SID=
ISG_AGENT_TWILIO_AUTH_TOKEN=
ISG_AGENT_TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# GOOGLE CALENDAR OAUTH2
# -----------------------------------------------------------------------------

ISG_AGENT_GOOGLE_CLIENT_ID=
ISG_AGENT_GOOGLE_CLIENT_SECRET=
# Full callback URL, e.g. https://dingdawg.ai/api/v1/oauth/google/callback
ISG_AGENT_GOOGLE_REDIRECT_URI=

# -----------------------------------------------------------------------------
# VAPI VOICE
# -----------------------------------------------------------------------------

ISG_AGENT_VAPI_API_KEY=

# -----------------------------------------------------------------------------
# MILA BRIDGE
# -----------------------------------------------------------------------------

# Bearer token for MiLA gateway integration
MILA_BRIDGE_TOKEN=

# MiLA bridge base URL (defaults to http://localhost:8421)
MILA_BRIDGE_URL=

# -----------------------------------------------------------------------------
# SECURITY / MISC
# -----------------------------------------------------------------------------

# Shared secret for remote-access localhost guard
ISG_REMOTE_SECRET=

# Cloudflare Turnstile secret key for bot prevention
ISG_AGENT_TURNSTILE_SECRET_KEY=

# Enable HSTS header: true | false (auto-enabled in production)
ISG_AGENT_ENABLE_HSTS=

# Comma-separated list of extra allowed email domains for registration
ALLOWED_EMAIL_DOMAINS=

# Comma-separated list of user IDs with finance admin privileges
FINANCE_ADMIN_USERS=

# Comma-separated list of user IDs with marketplace admin privileges
MARKETPLACE_ADMIN_USERS=

# Optional path to a YAML config file (overrides defaults)
ISG_AGENT_CONFIG_FILE=

# Optional path override for SQLite DB (bare env var, legacy alias)
AGENT1_DB_PATH=

# -----------------------------------------------------------------------------
# Nango Integration (OAuth provider bridge)
# -----------------------------------------------------------------------------
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=
NANGO_BASE_URL=https://api.nango.dev

# -----------------------------------------------------------------------------
# Zapier OAuth
# -----------------------------------------------------------------------------
ZAPIER_CLIENT_ID=
ZAPIER_CLIENT_SECRET=
