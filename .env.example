# =============================================================================
# ISG Agent 1 — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Gateway Security
# ---------------------------------------------------------------------------
# Secret key for signing tokens and securing internal communication.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ISG_AGENT_SECRET_KEY=generate-a-64-char-hex-secret-here

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Path to the SQLite database file. Relative paths resolve from gateway cwd.
ISG_AGENT_DB_PATH=./data/isg_agent.db

# ---------------------------------------------------------------------------
# LLM Provider API Keys
# ---------------------------------------------------------------------------
# At least one provider key is required for the agent brain to function.
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# ---------------------------------------------------------------------------
# Server Configuration
# ---------------------------------------------------------------------------
ISG_AGENT_HOST=127.0.0.1
ISG_AGENT_PORT=8900
ISG_AGENT_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Workspace
# ---------------------------------------------------------------------------
# Root directory for agent file operations. Skills are sandboxed to this path.
ISG_AGENT_WORKSPACE=./workspace

# ---------------------------------------------------------------------------
# Messaging Platform Tokens (optional, enable per bridge)
# ---------------------------------------------------------------------------
ISG_DISCORD_TOKEN=your-discord-bot-token-here
ISG_TELEGRAM_TOKEN=your-telegram-bot-token-here
