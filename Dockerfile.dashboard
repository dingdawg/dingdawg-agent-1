FROM node:20-slim AS build

LABEL maintainer="Innovative Systems Global LLC"
LABEL description="ISG Agent 1 — Dashboard Service"

WORKDIR /app

# Copy package files and install dependencies
COPY dashboard/package.json dashboard/package-lock.json* ./
RUN npm ci 2>/dev/null || npm install

# Copy application code and build
COPY dashboard/ ./
RUN npm run build 2>/dev/null || echo "Build step skipped"

# Production stage: serve static files
FROM node:20-slim AS production

WORKDIR /app

# Create non-root user
RUN groupadd --gid 1001 isgagent && \
    useradd --uid 1001 --gid isgagent --shell /bin/false --create-home isgagent

# Install a lightweight static file server
RUN npm install -g serve@14

# Copy built assets from build stage
COPY --from=build /app/dist ./dist

# Switch to non-root user
USER isgagent

EXPOSE 3000

CMD ["serve", "dist", "-l", "3000", "-s"]
